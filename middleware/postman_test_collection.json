        },
        "url": {
          "raw": "{{base_url}}/check",
          "host": ["{{base_url}}"],
          "path": ["check"]
        },
        "description": "Should detect bot signature (curl) and return blocked"
      }
    },
    {
      "name": "Check Rate Limit - Missing User Agent",
