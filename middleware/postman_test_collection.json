    {
  "name": "10. Rate Limit Checks",
  "item": [
    {
      "name": "Check Rate Limit - Allowed",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-API-Key",
            "value": "{{api_key}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"service_id\": \"user-service\",\n  \"endpoint\": \"/api/users\",\n  \"ip\": \"192.168.1.100\",\n  \"headers\": {\n    \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36\",\n    \"Accept\": \"application/json\"\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/check",
          "host": ["{{base_url}}"],
          "path": ["check"]
        },
        "description": "Dry-run rate limit check that should be allowed (first request)"
      }
    },
    {
      "name": "Check Rate Limit - With User ID",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
