    {
      "name": "9. Complete Workflow Examples",
      "item": [
        {
          "name": "Create Payment Service (Complete)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"payment-service\",\n  \"service_id\": \"payments-v1\",\n  \"name\": \"Payment Service\",\n  \"upstream_url\": \"http://payment-backend:8080\",\n  \"default_limits\": {\n    \"requests_per_second\": 50,\n    \"burst_size\": 100,\n    \"block_duration\": 300000000000\n  },\n  \"endpoints\": [\n    {\n      \"id\": \"health\",\n      \"path\": \"/health\",\n      \"method\": \"GET\",\n      \"limits\": {\"requests_per_second\": 1000, \"burst_size\": 2000},\n      \"priority\": 1\n    },\n    {\n      \"id\": \"list-payments\",\n      \"path\": \"/api/v1/payments\",\n      \"method\": \"GET\",\n      \"limits\": {\"requests_per_second\": 50, \"burst_size\": 100},\n      \"priority\": 10\n    },\n    {\n      \"id\": \"create-payment\",\n      \"path\": \"/api/v1/payments\",\n      \"method\": \"POST\",\n      \"limits\": {\"requests_per_second\": 20, \"burst_size\": 40, \"block_duration\": 600000000000},\n      \"priority\": 20\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/apis",
              "host": ["{{base_url}}"],
              "path": ["admin", "apis"]
            },
            "description": "Step 1: Create a complete payment service API with health check and standard endpoints"
          }
        },
        {
          "name": "Verify Creation",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/apis/payment-service",
              "host": ["{{base_url}}"],
              "path": ["admin", "apis", "payment-service"]
            },
            "description": "Step 2: Verify the API was created correctly"
          }
        },
        {
          "name": "Test Routing",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/apis/resolve?path=/api/v1/payments",
              "host": ["{{base_url}}"],
              "path": ["admin", "apis", "resolve"],
              "query": [
                {
                  "key": "path",
                  "value": "/api/v1/payments"
                }
              ]
            },
            "description": "Step 3: Test which rule would apply to a specific path"
          }
        },
        {
          "name": "Test Proxy (Simulated)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/payments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Step 4: Test the actual proxy endpoint (requires user token, not admin token)"
          }
        },
        {
          "name": "Monitor Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
